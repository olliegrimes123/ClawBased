# ============================================================
# ClawBased — Environment Configuration
# Fill in your own keys. Never commit the real .env file.
# ============================================================

# ── LLM Providers ──────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Preferred models (override defaults.json if set)
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── X (Twitter) — Browser Login ────────────────────────────
# ClawBased posts to X via the OpenClaw @browser tool (host browser).
# No API keys required. Instead, log in to X.com manually in the
# OpenClaw browser before starting the agent:
#
#   openclaw browser start
#   openclaw browser open https://x.com
#   (log in manually, then start the heartbeat)
#
# OpenClaw config (~/.openclaw/openclaw.json):
# {
#   "agents": { "defaults": { "sandbox": {
#     "mode": "non-main",
#     "browser": { "allowHostControl": true }
#   }}}
# }

# ── News & OSINT Data Sources ──────────────────────────────
NEWSAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CRYPTOCOMPARE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Agent Configuration ────────────────────────────────────
HEARTBEAT_CRON=0 */4 * * *
LOG_LEVEL=info
NODE_ENV=production

# ── Solana Treasury ────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
FEE_WALLET_ADDRESS=YOUR_POLYBASED_WALLET_PUBLIC_KEY
WALLET_PRIVATE_KEY=[1,2,3,...]
# Set to true to run with mock data (no real wallet needed)
SOLANA_SIMULATE=true
