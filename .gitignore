# ============================================================
# ClawBased — .gitignore
# The timeline must not be contaminated with secrets.
# ============================================================

# Dependencies
node_modules/
package-lock.json

# Environment & Secrets
.env
.env.*
!.env.example

# Private Keys & Credentials
*.pem
*.key
*.cert
*.p12
*.pfx
secrets/
credentials/

# Runtime Data
data/
cache/
tmp/
*.db
*.sqlite
*.sqlite3

# Logs
logs/
*.log

# OS Files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# Build Artifacts
dist/
build/
coverage/
.nyc_output/

# Docker (private orchestration)
docker-compose.override.yml
.docker/
